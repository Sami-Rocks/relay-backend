generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int              @id @default(autoincrement())
  email       String           @unique
  password    String
  firstName   String?
  lastName    String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  forms       Form[]
  submissions FormSubmission[]
}

enum FormKind {
  FORM
  POLL
  SURVEY
}

enum FormStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum FieldType {
  SHORT_TEXT
  LONG_TEXT
  MULTIPLE_CHOICE
}

enum DuplicateProtection {
  NONE
  BROWSER
  LOGIN
}

model Form {
  id                       Int                 @id @default(autoincrement())
  userId                   Int
  kind                     FormKind            @default(FORM)
  icon                     String?
  title                    String
  description              String?
  coverImageUrl            String?
  coverImagePublicId       String?
  status                   FormStatus          @default(DRAFT)
  requireLogin             Boolean             @default(false)
  allowAnonymous           Boolean             @default(true)
  allowMultipleSubmissions Boolean             @default(false)
  allowMultipleVotes       Boolean             @default(false)
  duplicateProtection      DuplicateProtection @default(BROWSER)
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  user                     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  fields                   FormField[]
  submissions              FormSubmission[]

  @@index([userId])
  @@index([kind])
  @@index([status])
}

model FormField {
  id          Int           @id @default(autoincrement())
  formId      Int
  type        FieldType
  label       String
  placeholder String?
  required    Boolean       @default(false)
  order       Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  form        Form          @relation(fields: [formId], references: [id], onDelete: Cascade)
  options     FieldOption[]
  answers     FormAnswer[]

  @@index([formId])
  @@index([type])
}

model FieldOption {
  id        Int       @id @default(autoincrement())
  fieldId   Int
  label     String
  value     String
  order     Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  field     FormField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@index([fieldId])
}

model FormSubmission {
  id                 Int          @id @default(autoincrement())
  formId             Int
  respondentId       Int?
  anonymousTokenHash String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  form               Form         @relation(fields: [formId], references: [id], onDelete: Cascade)
  respondent         User?        @relation(fields: [respondentId], references: [id], onDelete: SetNull)
  answers            FormAnswer[]

  @@index([formId])
  @@index([formId, createdAt, id])
  @@index([respondentId])
  @@index([formId, respondentId])
  @@index([anonymousTokenHash])
  @@index([formId, anonymousTokenHash])
}

model FormAnswer {
  id           Int            @id @default(autoincrement())
  submissionId Int
  fieldId      Int
  value        Json
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  submission   FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  field        FormField      @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([fieldId])
  @@index([fieldId, submissionId])
}
